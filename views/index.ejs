<!DOCTYPE html>
<html lang="zh-CN">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI云检测误差分析系统</title>
    <script src="<%= basePath %>/tailwindcss.js"></script>
    <link href="<%= basePath %>/font-awesome.min.css" rel="stylesheet">
    <link rel="stylesheet" href="<%= basePath %>/flatpickr.min.css">
    <script src="<%= basePath %>/flatpickr.min.js"></script>
    <script src="<%= basePath %>/zh.js"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#165DFF',
                        secondary: '#0FC6C2',
                        success: '#00B42A',
                        warning: '#FF7D00',
                        danger: '#F53F3F',
                        info: '#86909C',
                        'time-tab': '#F2F3F5',
                        'time-tab-active': '#3b82f6',
                    },
                    fontFamily: {
                        inter: ['Inter', 'system-ui', 'sans-serif'],
                    },
                    boxShadow: {
                        'card': '0 2px 14px 0 rgba(0, 0, 0, 0.06)',
                    }
                },
            }
        }
    </script>
    <style type="text/tailwindcss">
        @layer utilities {
            .content-auto {
                content-visibility: auto;
            }
            .scrollbar-hide {
                -ms-overflow-style: none;
                scrollbar-width: none;
            }
            .scrollbar-hide::-webkit-scrollbar {
                display: none;
            }
            .tab-active {
                @apply bg-time-tab-active text-white border-primary;
            }
            .color-scale {
                @apply h-3 w-full bg-gradient-to-r border border-gray-300;
            }
        }

        .map {
            height: 35vh;
            width: 100%;
        }
        .simple-label-tooltip {
            font-size: 0.875rem;
            /* text-sm */
            color: #1f2937;
            /* text-gray-800 */
            font-weight: 700;
            /* font-bold */
            background: transparent !important;
            border: none !important;
            box-shadow: none !important;
            z-index: 999;
        }
    </style>
    <style>
        /* 自定义滚动条样式 */
        ::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }

        /* 隐藏滚动条按钮 */
        ::-webkit-scrollbar-button {
            display: none;
        }

        ::-webkit-scrollbar-track {
            background: #f1f1f1;
            border-radius: 3px;
        }

        ::-webkit-scrollbar-thumb {
            background: #c1c1c1;
            border-radius: 3px;
        }

        ::-webkit-scrollbar-thumb:hover {
            background: #a8a8a8;
        }

        .spinner {
            display: inline-block;
            width: 20px;
            height: 20px;
            border: 3px solid rgba(59, 130, 246, 0.3);
            border-radius: 50%;
            border-top-color: #3b82f6;
            animation: spin 1s ease-in-out infinite;
            margin-right: 8px;
            vertical-align: middle;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        .loading-status {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(255, 255, 255, 0.8);
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .img-container {
            position: relative;
        }

        .img-content {
        }
    </style>
</head>

<body class="font-inter bg-gray-50 min-h-screen">
	    <%
		        const DISPLAY_TIME_OFFSET_HOURS = 8;
		        function padTimePart(value) {
		            return String(value).padStart(2, '0');
		        }
	        function parseRawDate(rawDate) {
	            const match = String(rawDate).match(/^(\d{4})-(\d{2})-(\d{2})$/);
	            if (!match) return null;
	            return {
	                year: Number(match[1]),
	                month: Number(match[2]),
	                day: Number(match[3]),
	            };
	        }
	        function parseRawDateTime(rawDateTime) {
	            const match = String(rawDateTime).match(/^(\d{4})-(\d{2})-(\d{2}) (\d{2}):(\d{2})$/);
	            if (!match) return null;
	            return {
                year: Number(match[1]),
                month: Number(match[2]),
                day: Number(match[3]),
                hour: Number(match[4]),
	                minute: Number(match[5]),
	            };
	        }
	        function createUTCDate(parts) {
	            return new Date(Date.UTC(
	                parts.year,
	                parts.month - 1,
	                parts.day,
	                parts.hour || 0,
	                parts.minute || 0
	            ));
	        }
	        function formatRawDate(date) {
	            return `${date.getUTCFullYear()}-${padTimePart(date.getUTCMonth() + 1)}-${padTimePart(date.getUTCDate())}`;
	        }
	        function formatRawDateTime(date) {
	            return `${formatRawDate(date)} ${padTimePart(date.getUTCHours())}:${padTimePart(date.getUTCMinutes())}`;
	        }
	        function addDays(rawDate, days) {
	            const parts = parseRawDate(rawDate);
	            if (!parts) return rawDate;
	            const date = createUTCDate(parts);
	            date.setUTCDate(date.getUTCDate() + days);
	            return formatRawDate(date);
	        }
	        function addDisplayOffsetDate(rawDateTime) {
	            const parts = parseRawDateTime(rawDateTime);
	            if (!parts) return null;
	            const date = createUTCDate(parts);
	            date.setUTCHours(date.getUTCHours() + DISPLAY_TIME_OFFSET_HOURS);
	            return date;
	        }
	        function buildDisplayReportOptions(displayDate, rawReportHourList) {
	            const options = [];
	            const rawDateCandidates = [addDays(displayDate, -1), displayDate, addDays(displayDate, 1)];
	            rawDateCandidates.forEach(rawDate => {
	                rawReportHourList.forEach(rawReportHour => {
	                    const rawDateTime = `${rawDate} ${rawReportHour}`;
	                    const displayDateTime = addDisplayOffsetDate(rawDateTime);
	                    if (!displayDateTime || formatRawDate(displayDateTime) !== displayDate) {
	                        return;
	                    }
	                    options.push({
	                        rawDate,
	                        rawReportHour,
	                        rawDateTime,
	                        displayTime: `${padTimePart(displayDateTime.getUTCHours())}:${padTimePart(displayDateTime.getUTCMinutes())}`,
	                        displayTimestamp: displayDateTime.getTime(),
	                    });
	                });
	            });
	            return options.sort((a, b) => a.displayTimestamp - b.displayTimestamp);
	        }
	        function formatDisplayForcastTime(rawForcastTime) {
	            const date = addDisplayOffsetDate(rawForcastTime);
	            if (!date) return rawForcastTime.slice(5);
	            return `${padTimePart(date.getUTCMonth() + 1)}-${padTimePart(date.getUTCDate())} ${padTimePart(date.getUTCHours())}:${padTimePart(date.getUTCMinutes())}`;
	        }
	        function buildForcastTimes(rawDate, rawReportHour) {
	            const parts = parseRawDateTime(`${rawDate} ${rawReportHour}`);
	            if (!parts) return [];
	            const baseDate = createUTCDate(parts);
	            const times = [];
	            for (let i = 1; i <= Number(TIME_LEN); i++) {
	                const forcastDate = new Date(baseDate.getTime());
	                forcastDate.setUTCHours(forcastDate.getUTCHours() + i * Number(TIME_GAP));
	                times.push(formatRawDateTime(forcastDate));
	            }
	            return times;
	        }
	        const initialDisplayDate = formatRawDate(addDisplayOffsetDate(currentReportTime) || createUTCDate(parseRawDate(startDate)));
	        const displayReportOptions = buildDisplayReportOptions(initialDisplayDate, reportHourList);
	        const activeReportOption = displayReportOptions.find(option => option.rawDateTime === currentReportTime) || displayReportOptions[0];
	        const activeForcastTimes = activeReportOption ? buildForcastTimes(activeReportOption.rawDate, activeReportOption.rawReportHour) : [];
	    %>
    <div class="max-w-12xl">
        <div class="flex">
            <div class="w-[27%] lg:w-[27%] rounded-xl p-2"></div>
            <!-- 左侧时间选择栏 -->
            <div class="w-50 lg:w-50 p-0 max-h-screen overflow-y-auto">
                <div class="flex items-center mb-2">
                    <div class="border border-gray-300 w-full flex mapTypeList">
                        <% [{ value: 'legacy', label: '旧版' }, { value: 'china', label: '全国' }].forEach((option) => { %>
                            <button
		                                class="tab-btn w-1/2 <%= activeMapType === option.value ? 'tab-active border-primary shadow-sm' : 'border-primary text-gray-500' %> map-type px-2 py-1 text-center font-bold text-base transition-all duration-200"
		                                value="<%= option.value %>"
		                                onclick="locationReload('mapType', this.value)"
		                                style="font-size: 12px;"
		                            ><%= option.label %></button>
                        <% }) %>
                    </div>
                </div>
                <div class="flex items-center mb-2">
                    <div class="border border-gray-300 w-full flex modelList">
                        <% for(let model of modelList) { %>
                            <button class="tab-btn w-1/2 <%= defaultModel === model ? 'tab-active border-primary shadow-sm' : 'border-primary text-gray-500' %> model px-2 py-1 text-center font-bold text-base transition-all duration-200" value=<%= model %> onclick="locationReload('model', this.value)" style="font-size: 12px;"><%= model %></button>
                        <% } %>
                    </div>
                </div>
                <div class="">
                    <h2 class="text-lg text-gray-800 flex items-center justify-around">
                        <span class="">起报时间选择</span>
                    </h2>
                    <input id="myID" placeholder="搜索时间..." class="w-full p-2 border border-gray-300 rounded-md focus:outline-none"/>
                </div>

                <div class="space-y-2 overflow-y-auto max-h-[calc(100vh-100px)] scrollbar-hide pr-1">
                    <!-- 时间标签页 - 今天 -->
                    <div class="grid max-h-[calc(30vh)] grid-cols-1 gap-2 overflow-y-auto custom-scrollbar reportList">
	                        <% if (displayReportOptions.length> 0) { %>
	                            <% displayReportOptions.forEach(option=> { %>
	                                <button onclick="locationReload('report', this.value, this.dataset.reportDate)"
	                                    class="time-option <%= activeReportOption && option.rawDateTime === activeReportOption.rawDateTime ? 'tab-active' : '' %> report border-b-2 border-gray-200 py-1 px-2 w-full flex flex-wrap justify-around text-center items-center"
	                                    value="<%= option.rawReportHour %>" data-time="<%= option.rawReportHour %>" data-report-date="<%= option.rawDate %>"
	                                >
	                                    <%= option.displayTime %>
	                                </button>
	                            <% }) %>
                        <% } else { %>
                            <p class="no-data">暂无时间数据</p>
                        <% } %>
                    </div>
                </div>

                <div class="mt-2">
                    <h2 class="text-lg text-gray-800 flex items-center justify-around">
                        <span class="">预报时间</span>

                    </h2>

                    <!-- 修改为单个切换按钮 -->
                    <div class="flex mt-2 mb-2 gap-2">
                        <button id="toggleBtn" class="bg-blue-500 text-white py-1 px-2 rounded flex items-center">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 1408 1600"><!-- Icon from Font Awesome 4 by Dave Gandy - https://scripts.sil.org/cms/scripts/page.php?site_id=nrsi&id=OFL --><path fill="currentColor" d="M1384 831L56 1569q-23 13-39.5 3T0 1536V64q0-26 16.5-36T56 31l1328 738q23 13 23 31t-23 31"/></svg>
                            播放
                        </button>
                    </div>

                    <div class="max-h-[calc(70vh)] overflow-scroll shadow-card forcastList">
	                        <% if (activeForcastTimes.length> 0) { %>
	                            <% activeForcastTimes.forEach((forcast, index)=> { %>
                                <button
                                    onclick="locationReload('forcast', this.value)"
                                    class="<%= index === 0 ? 'tab-active' : '' %> forcast py-2 px-2 w-full flex flex-wrap justify-around  text-center items-center"
                                    value="<%= forcast %>"
                                    data-img=""
                                >
                                    <div class=""><%= formatDisplayForcastTime(forcast) %></div>
                                </button>
                            <% }) %>
                        <% } else { %>
                            <p class="no-data">暂无时间数据</p>
                        <% } %>
                    </div>
                </div>
            </div>

            <!-- 右侧图片区域 -->
            <div class="w-full lg:w-full h-screen relative overflow-hidden pic-container bg-white flex flex-col">
                <!-- 图片网格 -->
                <div id="canvasImageStage" class="relative flex-1 min-h-0 overflow-hidden bg-white flex items-center justify-center">
                    <canvas id="weatherCanvas" class="max-w-full max-h-full object-contain transition-transform duration-300 ease-in-out"></canvas>
                </div>
            </div>
        </div>
    </div>

        <!-- 根据点击事件切换图片 -->
	    <script>
		        const DISPLAY_TIME_OFFSET_HOURS = 8;
		        const DEFAULT_MAP_TYPE = "<%= activeMapType || 'legacy' %>";
		        const MAP_LAYOUTS = {
		            legacy: {
		                mapAsset: 'china_transparent.png',
		                panelWidth: 672,
		                panelHeight: 494,
		                mode: 'legacyCrop',
		                preserveAspect: false,
		            },
			            china: {
			                mapAsset: 'whole_china_transparent_without_province.svg',
			                backgroundMode: 'blank',
			                backgroundAssets: [
			                    { key: 'logo', file: 'background_logo.png' },
			                    { key: 'cloudVertical', file: 'background_colorbar_cloud_vertical.png' },
			                    { key: 'errorVertical', file: 'background_colorbar_error_vertical.png' },
			                    { key: 'cloudHorizontal', file: 'background_colorbar_cloud_horizontal.png' },
			                ],
			                panelWidth: 664,
			                panelHeight: 400,
			                mode: 'direct',
			                dataRect: { x: 72, y: 40, width: 520, height: 320 },
			                preserveAspect: true,
			                targets: [
			                    { imageKey: 'inputs', x: -20, y: 145, width: 1080, height: 650 },
			                    { imageKey: 'preds', x: -20, y: 846, width: 1080, height: 650 },
			                    { imageKey: 'modified', x: 1080, y: 352, width: 1238, height: 746 },
			                ],
			            },
			        };
		        let currentMapType = Object.prototype.hasOwnProperty.call(MAP_LAYOUTS, DEFAULT_MAP_TYPE) ? DEFAULT_MAP_TYPE : 'legacy';
		        function getCurrentMapType() {
		            return Object.prototype.hasOwnProperty.call(MAP_LAYOUTS, currentMapType) ? currentMapType : 'legacy';
		        }
		        function withMapType(url) {
		            const separator = url.includes('?') ? '&' : '?';
		            return `${url}${separator}mapType=${encodeURIComponent(getCurrentMapType())}`;
		        }
		        function getCurrentMapLayout() {
		            return MAP_LAYOUTS[getCurrentMapType()] || MAP_LAYOUTS.legacy;
		        }
		        function setMapTypeButtonState(mapType) {
		            document.querySelectorAll('.map-type').forEach((button) => {
		                const isActive = button.value === mapType;
		                button.classList.toggle('tab-active', isActive);
		                button.classList.toggle('shadow-sm', isActive);
		                button.classList.toggle('text-gray-500', !isActive);
		            });
		        }
		        function setCurrentMapType(mapType) {
		            if (!Object.prototype.hasOwnProperty.call(MAP_LAYOUTS, mapType)) {
		                return false;
		            }
		            currentMapType = mapType;
		            setMapTypeButtonState(mapType);
		            if (typeof updatePanelViewControls === 'function') {
		                updatePanelViewControls();
		            }
		            if (typeof redrawCurrentComposite === 'function') {
		                redrawCurrentComposite();
		            }
		            return true;
		        }
		        function parseRawDate(rawDate) {
	            const match = String(rawDate).match(/^(\d{4})-(\d{2})-(\d{2})$/);
	            if (!match) {
	                return null;
	            }
	            return {
	                year: Number(match[1]),
	                month: Number(match[2]),
	                day: Number(match[3]),
	            };
	        }
	        function parseRawDateTime(rawDateTime) {
	            const match = String(rawDateTime).match(/^(\d{4})-(\d{2})-(\d{2}) (\d{2}):(\d{2})$/);
	            if (!match) {
	                return null;
	            }
	            return {
	                year: Number(match[1]),
	                month: Number(match[2]),
	                day: Number(match[3]),
	                hour: Number(match[4]),
	                minute: Number(match[5]),
	            };
	        }
	        function createUTCDate(parts) {
	            return new Date(Date.UTC(
	                parts.year,
	                parts.month - 1,
	                parts.day,
	                parts.hour || 0,
	                parts.minute || 0
	            ));
	        }
	        function padTimePart(value) {
	            return String(value).padStart(2, '0');
	        }
	        function formatRawDate(date) {
	            return `${date.getUTCFullYear()}-${padTimePart(date.getUTCMonth() + 1)}-${padTimePart(date.getUTCDate())}`;
	        }
	        function formatRawDateTime(date) {
	            return `${formatRawDate(date)} ${padTimePart(date.getUTCHours())}:${padTimePart(date.getUTCMinutes())}`;
	        }
	        function addDays(rawDate, days) {
	            const parts = parseRawDate(rawDate);
	            if (!parts) {
	                return rawDate;
	            }
	            const date = createUTCDate(parts);
	            date.setUTCDate(date.getUTCDate() + days);
	            return formatRawDate(date);
	        }
	        function addDisplayOffsetDate(rawDateTime) {
	            const parts = parseRawDateTime(rawDateTime);
	            if (!parts) {
	                return null;
	            }
	            const date = createUTCDate(parts);
	            date.setUTCHours(date.getUTCHours() + DISPLAY_TIME_OFFSET_HOURS);
	            return date;
	        }
	        function formatDisplayForcastTime(forcastTime) {
	            const displayDate = addDisplayOffsetDate(forcastTime);
	            if (!displayDate) {
	                return forcastTime.slice(5);
	            }
	            return `${padTimePart(displayDate.getUTCMonth() + 1)}-${padTimePart(displayDate.getUTCDate())} ${padTimePart(displayDate.getUTCHours())}:${padTimePart(displayDate.getUTCMinutes())}`;
	        }
	        function getReportHourList(model) {
	            const ECReportHourList = ("<%= ECReportHourList %>").split(',');
	            const CMAReportHourList = ("<%= CMAReportHourList %>").split(',');
	            return model === 'EC' ? ECReportHourList : CMAReportHourList;
	        }
	        function buildDisplayReportOptions(model, displayDate) {
	            const reportHourList = getReportHourList(model);
	            const rawDateCandidates = [addDays(displayDate, -1), displayDate, addDays(displayDate, 1)];
	            const options = [];
	            rawDateCandidates.forEach(rawDate => {
	                reportHourList.forEach(rawReportHour => {
	                    const rawDateTime = `${rawDate} ${rawReportHour}`;
	                    const displayDateTime = addDisplayOffsetDate(rawDateTime);
	                    if (!displayDateTime || formatRawDate(displayDateTime) !== displayDate) {
	                        return;
	                    }
	                    options.push({
	                        rawDate,
	                        rawReportHour,
	                        rawDateTime,
	                        displayTime: `${padTimePart(displayDateTime.getUTCHours())}:${padTimePart(displayDateTime.getUTCMinutes())}`,
	                        displayTimestamp: displayDateTime.getTime(),
	                    });
	                });
	            });
	            return options.sort((a, b) => a.displayTimestamp - b.displayTimestamp);
	        }
	        function generateForcastTimes(rawDate, rawReportHour) {
	            const parts = parseRawDateTime(`${rawDate} ${rawReportHour}`);
	            if (!parts) {
	                return [];
	            }
	            const baseDate = createUTCDate(parts);
	            const TIME_LEN = parseInt("<%= TIME_LEN %>", 10);
	            const TIME_GAP = parseInt("<%= TIME_GAP %>", 10);
	            const times = [];
	            for (let i = 1; i <= TIME_LEN; i++) {
	                const forcastDate = new Date(baseDate.getTime());
	                forcastDate.setUTCHours(forcastDate.getUTCHours() + i * TIME_GAP);
	                times.push(formatRawDateTime(forcastDate));
	            }
	            return times;
	        }
	        function findReportButton(rawReportHour, rawReportDate) {
	            return [...document.querySelectorAll('.report')].find((button) => {
	                return button.value === rawReportHour && button.dataset.reportDate === rawReportDate;
	            });
	        }
	        function getActiveReportDate() {
	            return document.querySelector('.tab-active.report')?.dataset.reportDate || document.querySelector('#myID').value;
	        }
	        function setDatePickerValue(displayDate) {
	            const input = document.querySelector('#myID');
	            if (!input) {
	                return;
	            }
	            if (input._flatpickr) {
	                input._flatpickr.setDate(displayDate, false);
	            } else {
	                input.value = displayDate;
	            }
	        }
	        function getDisplayDateFromReportTime(rawReportTime) {
	            const displayDate = rawReportTime ? addDisplayOffsetDate(rawReportTime) : null;
	            return displayDate ? formatRawDate(displayDate) : document.querySelector('#myID').value;
	        }
	        async function fetchLatestReportTime(model) {
	            const basePath = "<%= basePath %>";
		            const response = await fetch(withMapType(`${basePath}/latest/${encodeURIComponent(model)}`), { cache: 'no-store' });
	            if (!response.ok) {
	                return '';
	            }
	            const data = await response.json();
	            return data.currentReportTime || '';
	        }
	        let locationReloadRequestId = 0;
	        function loadIfCurrent(requestId, src) {
	            if (requestId === locationReloadRequestId && src) {
	                loadImg(src);
	            }
	        }
	        function cancelCurrentImageWork() {
	            if (window.pollInterval) {
	                clearInterval(window.pollInterval);
	                window.pollInterval = null;
	            }
	            if (window.currentImageRequest) {
	                window.currentImageRequest.abort();
	                window.currentImageRequest = null;
	            }
	        }
	        async function changeModelToLatest(model, requestId) {
	            let latestReportTime = '';
	            try {
	                latestReportTime = await fetchLatestReportTime(model);
	            } catch (err) {
	                latestReportTime = '';
	            }
	            if (requestId !== locationReloadRequestId) {
	                return '';
	            }
	            return changeModel(model, latestReportTime);
	        }
	        function changeModel(model, latestReportTime) {
	            const activeModelButton = document.querySelector('.tab-active.model');
	            const nextModelButton = document.querySelector(`.model[value="${model}"]`);
	            if (!nextModelButton) {
	                return '';
	            }
	            activeModelButton?.classList.remove('tab-active');
	            nextModelButton.classList.add('tab-active');
	            updatePanelViewControls();
	            const date = getDisplayDateFromReportTime(latestReportTime);
	            if (latestReportTime) {
	                setDatePickerValue(date);
	            }
	            const reportListDiv = document.querySelector('.reportList');
	            if (!reportListDiv) {
	                return '';
	            }
	            const reportOptions = buildDisplayReportOptions(model, date);
	            const latestReportOption = latestReportTime ? reportOptions.find((option) => option.rawDateTime === latestReportTime) : null;
	            const selectedReport = latestReportOption || reportOptions[0];
	            reportListDiv.innerHTML = reportOptions.length ? `
	                ${reportOptions.map((option, index)=> {
	                    return `<button
	                        onclick="locationReload('report', this.value, this.dataset.reportDate)"
	                        class="${selectedReport && option.rawDateTime === selectedReport.rawDateTime ? 'tab-active' : '' } time-option report border-b-2 border-gray-200 py-1 px-2 w-full flex flex-wrap justify-around text-center items-center"
	                        value="${option.rawReportHour}"
	                        data-report-date="${option.rawDate}"
	                        data-img=""
	                    >
	                        <div class="w-1/2"> ${option.displayTime} </div>
	                    </button>`
	                }).join('')}
	            ` : '<p class="no-data">暂无时间数据</p>'
	            if (!selectedReport) {
	                return '';
	            }
	            changeForcastAndReportTime(model, selectedReport.rawReportHour, selectedReport.rawDate);
	            const forcastHour = document.querySelector('.tab-active.forcast')?.value
	            if (!forcastHour) {
	                return '';
	            }
	            const reportTime = selectedReport.rawDate + ' ' + selectedReport.rawReportHour;
	            const forcastTime = forcastHour;
	            // 去掉日期中的所有符号和空格
	            const reportTimeReplace = reportTime.replace(/[^\d]/g, '');
            const forcastTimeReplace = forcastTime.replace(/[^\d]/g, '');
            return `${model}/${reportTimeReplace}/${forcastTimeReplace}`;
        }

	        function changeForcastAndReportTime(model, reportHour, rawReportDate) {
	            if (!model || !reportHour) {
	                return '';
	            }
	            // 获取ejs变量forcastHourList
	            document.querySelector('.tab-active.report')?.classList.remove('tab-active');
	            rawReportDate = rawReportDate || findReportButton(reportHour, getActiveReportDate())?.dataset.reportDate || document.querySelector('#myID').value;
	            findReportButton(reportHour, rawReportDate)?.classList.add('tab-active');
	            const forcastTimes = generateForcastTimes(rawReportDate, reportHour);
	            const forcastListDiv = document.querySelector('.forcastList');
	            if (!forcastListDiv) {
	                return '';
	            }
	            forcastListDiv.innerHTML = forcastTimes.length ? `
	                ${forcastTimes.map((forcast, index)=> {
	                    return `<button
	                        onclick="locationReload('forcast', this.value)"
	                        class="${index === 0 ? 'tab-active' : '' } forcast py-2 px-2 w-full flex flex-wrap justify-around  text-center items-center"
                        value="${forcast}"
                        data-img=""
                    >
                        <div> ${formatDisplayForcastTime(forcast)} </div>
	                    </button>`
	                }).join('')}
	            ` : '<p class="no-data">暂无时间数据</p>'
	            const reportTime = rawReportDate + ' ' + reportHour;
	            const forcastTime = forcastTimes[0];
	            if (!forcastTime) {
	                buttons = document.querySelectorAll('.forcast');
	                return '';
	            }

	            // 去掉日期中的所有符号和空格
	            const reportTimeReplace = reportTime.replace(/[^\d]/g, '');
            const forcastTimeReplace = (forcastTime).replace(/[^\d]/g, '');
            buttons = document.querySelectorAll('.forcast');
            return `${model}/${reportTimeReplace}/${forcastTimeReplace}`;
        }

	        function changeReportTime(model, reportHour, forcastHour) {
	            const activeForcastButton = document.querySelector('.tab-active.forcast');
	            const nextForcastButton = document.querySelector(`.forcast[value="${forcastHour}"]`);
	            if (!model || !reportHour || !forcastHour || !nextForcastButton) {
	                return '';
	            }
	            activeForcastButton?.classList.remove('tab-active');
	            nextForcastButton.classList.add('tab-active');
	            const rawReportDate = getActiveReportDate();
	            const reportTime = rawReportDate + ' ' + reportHour;
	            const forcastTime = forcastHour;
            // 去掉日期中的所有符号和空格
            const reportTimeReplace = reportTime.replace(/[^\d]/g, '');
	            const forcastTimeReplace = forcastTime.replace(/[^\d]/g, '');
	            return `${model}/${reportTimeReplace}/${forcastTimeReplace}`;
	        }

	        function changeMapType(mapType, requestId) {
	            if (!setCurrentMapType(mapType)) {
	                return Promise.resolve('');
	            }
	            const activeModel = document.querySelector('.tab-active.model')?.value;
	            return activeModel ? changeModelToLatest(activeModel, requestId) : Promise.resolve('');
	        }

	        function locationReload(type, value, rawReportDate) {
	            const requestId = ++locationReloadRequestId;
	            cancelCurrentImageWork();
	            let nextSrc = '';
	            switch(type) {
	                case 'mapType':
	                    changeMapType(value, requestId).then((src) => loadIfCurrent(requestId, src));
	                    return;
	                case 'model':
	                    changeModelToLatest(value, requestId).then((src) => loadIfCurrent(requestId, src));
	                    return;
	                case 'report':
	                    nextSrc = changeForcastAndReportTime(document.querySelector('.tab-active.model')?.value, value, rawReportDate);
	                    break;
	                case 'forcast':
	                    nextSrc = changeReportTime(document.querySelector('.tab-active.model')?.value, document.querySelector('.tab-active.report')?.value, value);
	                    break;
	            }
	            if (nextSrc) {
	                loadIfCurrent(requestId, nextSrc);
	            }
	        }
    </script>




<script>
	    const startDate = "<%= initialDisplayDate %>"
	    const minSelectableDate = "2025-07-22"
	    flatpickr("#myID", {
        locale: 'zh',
	        // minDate: minSelectableDate,
        disable: [
            function(date) {
                return new Date(date).getTime() > new Date().getTime();
            }
        ],
		        defaultDate: startDate,
		        onChange: (selectedDates, dateStr, instance) => {
		            const requestId = ++locationReloadRequestId;
		            cancelCurrentImageWork();
		            const nextSrc = changeModel(document.querySelector('.tab-active.model')?.value);
		            if (nextSrc) {
		                loadIfCurrent(requestId, nextSrc);
		            }
		        }
		    });

</script>


    <script>
        const cacheList = new Set();
        let currentImagePathFragment = '';
        let currentImageDefaultTitle = '';
        let currentImageTitle = '';
        let currentCompositeState = null;
        let imageTitleRequestId = 0;
        const PANEL_LABELS_BY_MODEL = {
            EC: {
                inputs: 'EC数值模式预报总云量',
                preds: 'EC数值模式总云量误差预测',
                modified: '校正后的EC数值模式预报总云量',
            },
            CMA: {
                inputs: 'CMA数值模式预报总云量',
                preds: 'CMA数值模式总云量误差预测',
                modified: '校正后的CMA数值模式预报总云量',
            },
        };
        let panelViewMode = 'overview';
        let focusedPanelKey = 'modified';

        function getCurrentModel() {
            return document.querySelector('.tab-active.model')?.value || "<%= defaultModel %>";
        }

        function getPanelLabelsForModel(model) {
            return PANEL_LABELS_BY_MODEL[model] || PANEL_LABELS_BY_MODEL.EC;
        }

        function isPanelFocusAvailable() {
            return getCurrentMapType() === 'china';
        }

        function updatePanelViewControls() {
            const focusAvailable = isPanelFocusAvailable();
            if (!focusAvailable && panelViewMode === 'focus') {
                panelViewMode = 'overview';
            }
        }

        function setPanelViewMode(nextMode, panelKey) {
            const panelLabels = getPanelLabelsForModel(getCurrentModel());
            if (isPanelFocusAvailable() && nextMode === 'focus' && Object.prototype.hasOwnProperty.call(panelLabels, panelKey)) {
                panelViewMode = 'focus';
                focusedPanelKey = panelKey;
            } else {
                panelViewMode = 'overview';
            }
            updatePanelViewControls();
            redrawCurrentComposite();
        }

        function getCanvasBasePoint(event, canvas) {
            const rect = canvas.getBoundingClientRect();
            if (!rect.width || !rect.height || !canvas.width || !canvas.height) {
                return null;
            }
            const canvasX = (event.clientX - rect.left) * (canvas.width / rect.width);
            const canvasY = (event.clientY - rect.top) * (canvas.height / rect.height);
            return {
                x: canvasX / (canvas.width / 2250),
                y: canvasY / (canvas.height / 1500),
            };
        }

        function handleCanvasPanelClick(event) {
            if (!isPanelFocusAvailable()) {
                return;
            }
            if (panelViewMode === 'focus') {
                setPanelViewMode('overview');
                return;
            }
            if (!currentCompositeState?.panelHitAreas?.length) {
                return;
            }
            const point = getCanvasBasePoint(event, event.currentTarget);
            if (!point) {
                return;
            }
            const hitArea = [...currentCompositeState.panelHitAreas].reverse().find((area) => {
                return point.x >= area.x
                    && point.x <= area.x + area.width
                    && point.y >= area.y
                    && point.y <= area.y + area.height;
            });
            if (hitArea) {
                setPanelViewMode('focus', hitArea.imageKey);
            }
        }

        function setupPanelViewInteractions() {
            document.getElementById('weatherCanvas')?.addEventListener('click', handleCanvasPanelClick);
            updatePanelViewControls();
        }

        function parseCompactDateTime(value) {
            const match = String(value).match(/^(\d{4})(\d{2})(\d{2})(\d{2})(\d{2})$/);
            if (!match) {
                return null;
            }
            return createUTCDate({
                year: Number(match[1]),
                month: Number(match[2]),
                day: Number(match[3]),
                hour: Number(match[4]),
                minute: Number(match[5]),
            });
        }

        function formatTitleDateTime(date) {
            return `${formatRawDate(date)} ${padTimePart(date.getUTCHours())}:${padTimePart(date.getUTCMinutes())}`;
        }

        function buildDefaultImageTitle(src) {
            const params = String(src).split('/');
            if (params.length < 3) {
                return '起报时间（北京时）';
            }
            const reportDate = params[params.length - 2];
            const forcastDate = params[params.length - 1];
            const reportTime = parseCompactDateTime(reportDate);
            const forcastTime = parseCompactDateTime(forcastDate);
            if (!reportTime || !forcastTime) {
                return '起报时间（北京时）';
            }
            const displayReportTime = new Date(reportTime.getTime());
            displayReportTime.setUTCHours(displayReportTime.getUTCHours() + DISPLAY_TIME_OFFSET_HOURS);
            const durationHours = Math.max(0, Math.round((forcastTime.getTime() - reportTime.getTime()) / (60 * 60 * 1000)));
            return `起报时间（北京时）${formatTitleDateTime(displayReportTime)}(+${durationHours}h)`;
        }

	        function getImageTitleUrl(src) {
	            const basePath = "<%= basePath %>";
	            return withMapType(`${basePath}/title/${src}`);
	        }

        function setImageTitleText(title) {
            currentImageTitle = title || currentImageDefaultTitle || '';
            redrawCurrentComposite();
        }

        function redrawCurrentComposite() {
            if (!currentCompositeState) {
                return;
            }
	            drawComposite(
	                currentCompositeState.canvas,
	                currentCompositeState.ctx,
	                currentCompositeState.images,
	                currentCompositeState.info,
	                currentCompositeState.layout
	            );
        }

        async function syncImageTitle(src) {
            const requestId = ++imageTitleRequestId;
            currentImagePathFragment = src;
            currentImageDefaultTitle = buildDefaultImageTitle(src);
            setImageTitleText(currentImageDefaultTitle);

            try {
                const response = await fetch(getImageTitleUrl(src), { cache: 'no-store' });
                if (requestId !== imageTitleRequestId || currentImagePathFragment !== src || !response.ok) {
                    return;
                }
                const data = await response.json();
                const customTitle = Boolean(data.isCustom && data.title) ? data.title : '';
                setImageTitleText(customTitle || currentImageDefaultTitle);
            } catch (err) {
                if (requestId === imageTitleRequestId && currentImagePathFragment === src) {
                    setImageTitleText(currentImageDefaultTitle);
                }
            }
        }

        function getImgUrlList(src) {
            const params = src.split('/');
            const model = params[params.length - 3];
            const reportTime = params[params.length - 2];
	            const imgUrlList = [];
	            const reportDate = `${reportTime.slice(0, 4)}-${reportTime.slice(4, 6)}-${reportTime.slice(6, 8)}`;
	            const reportHour = reportTime.slice(8,10) + ':' + reportTime.slice(10,12);
	            let hourList = generateForcastTimes(reportDate, reportHour);
	            hourList = hourList.map((hour) => {
                hour = hour.replaceAll(' ', '');
                hour = hour.replaceAll(':', '');
                hour = hour.replaceAll('-', '');
                return hour;
	            })
	            hourList.forEach((hour) => {
	                imgUrlList.push(`${model}/${reportTime}/${hour}`);
	            })
            return imgUrlList;
        }
	    function loadImg(src) {
	        const basePath = "<%= basePath %>"
	        const selectionRequestId = locationReloadRequestId;
	        const layout = getCurrentMapLayout();
	        currentCompositeState = null;
	        syncImageTitle(src);
        // 清除可能存在的轮询定时器
        if (window.pollInterval) {
            clearInterval(window.pollInterval);
            window.pollInterval = null;
        }

        const imgList = getImgUrlList(src);
	        imgList.forEach((img) => {
	            ['inputs.png', 'preds-inputs.png', 'modified.png'].forEach(file => {
	                const cacheKey = `${getCurrentMapType()}/${img}/${file}`;
	                if (cacheList.has(cacheKey)) {
	                    return;
	                }
	                cacheList.add(cacheKey);
	                // 预加载子图片
	                fetch(withMapType(`${basePath}/picture/${img}/${file}`));
	            });
	        })

        const canvas = document.getElementById('weatherCanvas');
        const ctx = canvas.getContext('2d');
        const statusElement = document.querySelector('.loading-status') || createStatusElement();
        statusElement.style.display = 'none';

        if (window.currentImageRequest) {
            window.currentImageRequest.abort();
            window.currentImageRequest = null;
        }

        const abortController = new AbortController();
        window.currentImageRequest = abortController;
	        const isCurrentImageRequest = () => {
	            return selectionRequestId === locationReloadRequestId
	                && window.currentImageRequest === abortController
	                && !abortController.signal.aborted
	                && currentImagePathFragment === src;
	        };

        // 获取时间信息用于绘制
        const params = src.split('/');
        const model = params[0];
        const reportStr = params[1];
        const forcastStr = params[2];

        const reportTime = parseCompactDateTime(reportStr);
        const forcastTime = parseCompactDateTime(forcastStr);
	        if (!reportTime || !forcastTime) {
	            statusElement.textContent = '参数错误';
	            statusElement.className = 'loading-status text-center py-4 text-orange-600';
	            statusElement.style.display = 'flex';
	            currentCompositeState = null;
	            return;
        }

        const displayReportTime = new Date(reportTime.getTime());
        displayReportTime.setUTCHours(displayReportTime.getUTCHours() + DISPLAY_TIME_OFFSET_HOURS);
        const displayForcastTime = new Date(forcastTime.getTime());
        displayForcastTime.setUTCHours(displayForcastTime.getUTCHours() + DISPLAY_TIME_OFFSET_HOURS);
        
        const durationHours = Math.max(0, Math.round((forcastTime.getTime() - reportTime.getTime()) / (60 * 60 * 1000)));

        const info = {
            model,
            reportTime: formatTitleDateTime(displayReportTime),
            forcastTime: formatTitleDateTime(displayForcastTime),
            duration: `(+${durationHours}h)`
        };

        // 并行加载所有资源，允许部分失败
        const loadImage = (url) => {
            return new Promise((resolve) => {
                const img = new Image();
                img.onload = () => resolve(img);
                img.onerror = () => {
                    console.error(`图片加载失败: ${url}`);
                    resolve(null);
                };
                img.src = url;
            });
        };

	        const fetchImageBlob = (fileName) => {
	            return fetch(withMapType(`${basePath}/picture/${src}/${fileName}`), { signal: abortController.signal })
	                .then(res => {
	                    if (res.status === 202) throw new Error('数据预测中');
	                    if (res.status !== 200) return null;
                    return res.blob();
                })
                .then(blob => {
                    if (!blob) return null;
                    const url = URL.createObjectURL(blob);
                    return loadImage(url).then((img) => {
                        URL.revokeObjectURL(url);
                        return img;
                    });
                })
                .catch(err => {
                    if (err.name === 'AbortError') throw err;
                    if (err.message === '数据预测中') throw err;
                    console.warn(`无法获取图片: ${fileName}`, err);
                    return null;
                });
	        };

		        const backgroundUrl = layout.backgroundMode === 'blank'
		            ? ''
		            : (model === 'EC' ? `${basePath}/background_ec.png` : `${basePath}/background_cma.png`);
		        const backgroundPromise = backgroundUrl ? loadImage(backgroundUrl) : Promise.resolve(null);
		        const backgroundAssetList = layout.backgroundAssets || [];
		        const backgroundAssetPromises = backgroundAssetList.map((asset) => {
		            return loadImage(`${basePath}/${asset.file}`).then((img) => [asset.key, img]);
		        });
		        const mapUrl = `${basePath}/${layout.mapAsset}`;

		        Promise.all([
		            fetchImageBlob('inputs.png'),
		            fetchImageBlob('preds-inputs.png'),
		            fetchImageBlob('modified.png'),
		            backgroundPromise,
		            loadImage(mapUrl),
		            ...backgroundAssetPromises
		        ]).then(([imgInputs, imgPreds, imgModified, imgBg, imgChinaTrans, ...backgroundAssetEntries]) => {
		            if (!isCurrentImageRequest()) {
		                return;
		            }
	            statusElement.style.display = 'none';
	            const hasAllLayers = imgInputs && imgPreds && imgModified;
	            const hasBackground = layout.backgroundMode === 'blank' || imgBg;
	            const backgroundAssets = {};
	            backgroundAssetEntries.forEach(([key, img]) => {
	                if (img) {
	                    backgroundAssets[key] = img;
	                }
	            });
	            if (hasBackground && imgChinaTrans && hasAllLayers) {
	                currentCompositeState = {
	                    canvas,
	                    ctx,
	                    images: { 
	                    inputs: imgInputs, 
	                    preds: imgPreds, 
	                    modified: imgModified,
		                    bg: imgBg,
		                    map: imgChinaTrans,
		                    backgroundAssets
		                    },
		                    info,
		                    layout
	                };
                redrawCurrentComposite();
	            } else if (hasBackground && imgChinaTrans && (imgInputs || imgPreds || imgModified)) {
	                currentCompositeState = {
	                    canvas,
	                    ctx,
                    images: { 
                    inputs: imgInputs, 
                    preds: imgPreds, 
	                    modified: imgModified,
		                    bg: imgBg,
		                    map: imgChinaTrans,
		                    backgroundAssets
		                    },
	                    info,
	                    layout
	                };
                redrawCurrentComposite();
            } else {
                throw new Error('暂无数据');
            }
        }).catch(error => {
            if (error.name === 'AbortError' || !isCurrentImageRequest()) return;

            if (error.message === '数据预测中') {
                statusElement.innerHTML = '<div class="spinner"></div> 模型预测中...';
                statusElement.className = 'loading-status text-center py-4 text-blue-600';
                window.pollInterval = setInterval(() => {
                    if (document.querySelector('.loading-status')?.textContent.includes('模型预测中')) {
                        loadImg(src);
                    } else {
                        clearInterval(window.pollInterval);
                    }
                }, 50000);
            } else {
                statusElement.textContent = error.message || '暂无数据';
                statusElement.className = 'loading-status text-center py-4 text-orange-600';
            }
            statusElement.style.display = 'flex';
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            currentCompositeState = null;
        });
    }

	    function drawComposite(canvas, ctx, images, info, layout) {
	        layout = layout || getCurrentMapLayout();
	        const baseWidth = 2250;
	        const baseHeight = 1500;
	        canvas.width = images.bg ? (images.bg.naturalWidth || images.bg.width || baseWidth) : baseWidth;
	        canvas.height = images.bg ? (images.bg.naturalHeight || images.bg.height || baseHeight) : baseHeight;
	        
	        const isFocusView = panelViewMode === 'focus' && isPanelFocusAvailable();
	        ctx.clearRect(0, 0, canvas.width, canvas.height);
	        if (layout.backgroundMode === 'blank' || !images.bg) {
	            ctx.fillStyle = '#ffffff';
	            ctx.fillRect(0, 0, canvas.width, canvas.height);
	        } else {
	            ctx.drawImage(images.bg, 0, 0, canvas.width, canvas.height);
	        }

        const scaleX = canvas.width / baseWidth;
        const scaleY = canvas.height / baseHeight;
        ctx.save();
        ctx.scale(scaleX, scaleY);

        const baseTitle = currentImageTitle || currentImageDefaultTitle || `起报时间${info.reportTime}${info.duration}`;
        const focusedPanelLabel = isFocusView ? getPanelLabelsForModel(getCurrentModel())[focusedPanelKey] || '' : '';
        const titleLines = [baseTitle];
        const titleBlockHeight = 120;
        const titleLineGap = 0;
        const minTitleFontSize = 42;
        let titleFontSize = 58;
        const maxTitleWidth = 2060;
        ctx.fillStyle = '#000000';
        ctx.textAlign = 'center';
        ctx.textBaseline = 'top';
        do {
            ctx.font = `${titleFontSize}px SimHei, "Microsoft YaHei", sans-serif`;
            const titleFitsWidth = titleLines.every((line) => ctx.measureText(line).width <= maxTitleWidth);
            const titleHeight = titleLines.length * titleFontSize + (titleLines.length - 1) * titleLineGap;
            if ((titleFitsWidth && titleHeight <= titleBlockHeight) || titleFontSize <= minTitleFontSize) {
                break;
            }
            titleFontSize -= 2;
        } while (true);
        const titleX = baseWidth / 2;
        const titleHeight = titleLines.length * titleFontSize + (titleLines.length - 1) * titleLineGap;
        const titleY = (titleBlockHeight - titleHeight) / 2;
	        titleLines.forEach((line, index) => {
	            ctx.fillText(line, titleX, titleY + index * (titleFontSize + titleLineGap));
	        });

	        function getBackgroundAsset(key) {
	            return images.backgroundAssets ? images.backgroundAssets[key] : null;
	        }

	        function drawBackgroundAsset(key, x, y, width, height) {
	            const asset = getBackgroundAsset(key);
	            if (!asset) {
	                return;
	            }
	            const drawWidth = width || asset.naturalWidth || asset.width;
	            const drawHeight = height || asset.naturalHeight || asset.height;
	            ctx.drawImage(asset, x, y, drawWidth, drawHeight);
	        }

	        function drawLayoutLogo() {
	            if (layout.backgroundMode !== 'blank') {
	                return;
	            }
	            drawBackgroundAsset('logo', 40, 8, 199, 106);
	        }

	        function drawOverviewPanelTitle(label, area) {
	            if (!label || !area) {
	                return;
	            }
	            const maxWidth = area.width;
	            const minFontSize = 20;
	            let fontSize = 28;
	            ctx.save();
	            ctx.fillStyle = '#000000';
	            ctx.textAlign = 'center';
	            ctx.textBaseline = 'top';
	            do {
	                ctx.font = `${fontSize}px SimHei, "Microsoft YaHei", sans-serif`;
	                if (ctx.measureText(label).width <= maxWidth || fontSize <= minFontSize) {
	                    break;
	                }
	                fontSize -= 2;
	            } while (true);
	            ctx.fillText(label, area.x + area.width / 2, Math.max(titleBlockHeight + 8, area.y - 34));
	            ctx.restore();
	        }

	        function getVerticalColorbarKey(imageKey) {
	            return imageKey === 'preds' ? 'errorVertical' : 'cloudVertical';
	        }

	        function getVerticalColorbarSize(colorbarKey) {
	            return colorbarKey === 'errorVertical'
	                ? { width: 97, height: 526 }
	                : { width: 96, height: 526 };
	        }

	        function drawOverviewDecorations(panelAreas) {
	            if (layout.backgroundMode !== 'blank') {
	                return;
	            }
	            const labels = getPanelLabelsForModel(getCurrentModel());
	            const areaByKey = {};
	            panelAreas.forEach((area) => {
	                areaByKey[area.imageKey] = area;
	                drawOverviewPanelTitle(labels[area.imageKey], area);
	            });

	            const inputsArea = areaByKey.inputs;
	            const predsArea = areaByKey.preds;
	            const modifiedArea = areaByKey.modified;
	            if (inputsArea) {
	                drawBackgroundAsset(
	                    'cloudVertical',
		                    inputsArea.x + inputsArea.width - 96,
	                    inputsArea.y + (inputsArea.height - 526) / 2,
	                    96,
	                    526
	                );
	            }
	            if (predsArea) {
	                drawBackgroundAsset(
	                    'errorVertical',
		                    predsArea.x + predsArea.width - 97,
	                    predsArea.y + (predsArea.height - 526) / 2,
	                    97,
	                    526
	                );
	            }
	            if (modifiedArea) {
	                drawBackgroundAsset(
	                    'cloudHorizontal',
	                    modifiedArea.x + (modifiedArea.width - 836) / 2,
		                    modifiedArea.y + modifiedArea.height + 18,
	                    836,
	                    88
	                );
	            }
	        }

	        drawLayoutLogo();

	        function createMapPanel(dataImg, renderScale) {
	            const panelWidth = layout.panelWidth;
	            const panelHeight = layout.panelHeight;
	            const normalizedRenderScale = Number.isFinite(renderScale) && renderScale > 0 ? renderScale : 1;
	            const renderWidth = Math.max(1, Math.round(panelWidth * normalizedRenderScale));
	            const renderHeight = Math.max(1, Math.round(panelHeight * normalizedRenderScale));

	            const panelCanvas = document.createElement('canvas');
	            panelCanvas.width = renderWidth;
            panelCanvas.height = renderHeight;
            panelCanvas.logicalWidth = panelWidth;
            panelCanvas.logicalHeight = panelHeight;
            const panelCtx = panelCanvas.getContext('2d');
            panelCtx.save();
            panelCtx.scale(renderWidth / panelWidth, renderHeight / panelHeight);
            panelCtx.fillStyle = '#ffffff';
	            panelCtx.fillRect(0, 0, panelWidth, panelHeight);

	            if (dataImg) {
	                if (layout.mode === 'direct') {
	                    const rect = layout.dataRect;
	                    panelCtx.drawImage(dataImg, rect.x, rect.y, rect.width, rect.height);
	                } else {
	                    const dataSize = 590;
	                    const cropHeight = 454;
	                    const cropTop = (dataSize - cropHeight) / 2;
	                    const pasteX = (panelWidth - dataSize) / 2;
	                    const pasteY = (panelHeight - cropHeight) / 2;
	                    const scaledCanvas = document.createElement('canvas');
	                    scaledCanvas.width = dataSize;
	                    scaledCanvas.height = dataSize;
	                    const scaledCtx = scaledCanvas.getContext('2d');
	                    scaledCtx.fillStyle = '#ffffff';
	                    scaledCtx.fillRect(0, 0, dataSize, dataSize);
	                    scaledCtx.drawImage(dataImg, 0, 0, dataSize, dataSize);
	                    panelCtx.drawImage(scaledCanvas, 0, cropTop, dataSize, cropHeight, pasteX, pasteY, dataSize, cropHeight);
	                }
	            }

	            panelCtx.drawImage(images.map, 0, 0, panelWidth, panelHeight);
	            panelCtx.restore();
	            return panelCanvas;
	        }

	        function drawPanel(panelCanvas, panel) {
	            const panelSourceWidth = panelCanvas.logicalWidth || panelCanvas.width;
	            const panelSourceHeight = panelCanvas.logicalHeight || panelCanvas.height;
	            if (!layout.preserveAspect) {
	                ctx.drawImage(panelCanvas, panel.x, panel.y, panel.width, panel.height);
	                return {
	                    x: panel.x,
	                    y: panel.y,
	                    width: panel.width,
	                    height: panel.height,
	                };
	            }
	            const scale = Math.min(panel.width / panelSourceWidth, panel.height / panelSourceHeight);
	            const width = panelSourceWidth * scale;
	            const height = panelSourceHeight * scale;
	            const x = panel.x + (panel.width - width) / 2;
	            const y = panel.y + (panel.height - height) / 2;
	            ctx.drawImage(panelCanvas, x, y, width, height);
	            return { x, y, width, height };
	        }

	        function getDirectPanelArea(panel) {
	            if (!layout.preserveAspect) {
	                return {
	                    x: panel.x,
	                    y: panel.y,
	                    width: panel.width,
	                    height: panel.height,
	                };
	            }
	            const scale = Math.min(panel.width / layout.panelWidth, panel.height / layout.panelHeight);
	            const width = layout.panelWidth * scale;
	            const height = layout.panelHeight * scale;
	            return {
	                x: panel.x + (panel.width - width) / 2,
	                y: panel.y + (panel.height - height) / 2,
	                width,
	                height,
	            };
	        }

	        function drawDirectMapPanel(dataImg, x, y, width, height) {
	            const panelScaleX = width / layout.panelWidth;
	            const panelScaleY = height / layout.panelHeight;

	            ctx.save();
	            ctx.fillStyle = '#ffffff';
	            ctx.fillRect(x, y, width, height);

	            if (dataImg) {
	                if (layout.mode === 'direct') {
	                    const rect = layout.dataRect;
	                    ctx.drawImage(
	                        dataImg,
	                        x + rect.x * panelScaleX,
	                        y + rect.y * panelScaleY,
	                        rect.width * panelScaleX,
	                        rect.height * panelScaleY
	                    );
	                } else {
	                    const panelCanvas = createMapPanel(dataImg, Math.max(panelScaleX, panelScaleY));
	                    ctx.drawImage(panelCanvas, x, y, width, height);
	                    ctx.restore();
	                    return;
	                }
	            }

	            ctx.drawImage(images.map, x, y, width, height);
	            ctx.restore();
	        }

	        ctx.globalCompositeOperation = 'source-over';
	        const defaultTargets = [
	            { imageKey: 'inputs', x: 115, y: 194, width: 800, height: 550 },
	            { imageKey: 'preds', x: 115, y: 829, width: 800, height: 550 },
	            { imageKey: 'modified', x: 1125, y: 414, width: 1034, height: 710 },
	        ];
	        const panels = (layout.targets || defaultTargets).map((panel) => {
	            return {
	                ...panel,
	                image: images[panel.imageKey],
	            };
	        });
	        const panelHitAreas = [];
	        if (isFocusView) {
	            const focusPanel = panels.find((panel) => panel.imageKey === focusedPanelKey) || panels[0];
	            if (focusPanel) {
	                const contentTop = titleBlockHeight;
	                const focusLabelHeight = 100;
	                const focusLabelGap = 24;
	                ctx.fillStyle = '#ffffff';
	                ctx.fillRect(0, titleBlockHeight, baseWidth, baseHeight - titleBlockHeight);
	                if (focusedPanelLabel) {
	                    let focusLabelFontSize = 52;
	                    const minFocusLabelFontSize = 34;
	                    ctx.fillStyle = '#000000';
	                    ctx.textAlign = 'center';
	                    ctx.textBaseline = 'top';
	                    do {
	                        ctx.font = `${focusLabelFontSize}px SimHei, "Microsoft YaHei", sans-serif`;
	                        if (ctx.measureText(focusedPanelLabel).width <= maxTitleWidth || focusLabelFontSize <= minFocusLabelFontSize) {
	                            break;
	                        }
	                        focusLabelFontSize -= 2;
	                    } while (true);
	                    const focusLabelY = contentTop + (focusLabelHeight - focusLabelFontSize) / 2;
	                    ctx.fillText(focusedPanelLabel, titleX, focusLabelY);
	                }
	                const panelTop = contentTop + focusLabelHeight + focusLabelGap;
	                const maxWidth = baseWidth - 160;
	                const maxHeight = baseHeight - panelTop - 40;
	                const colorbarKey = getVerticalColorbarKey(focusPanel.imageKey);
	                const colorbarAsset = getBackgroundAsset(colorbarKey);
	                const colorbarSize = getVerticalColorbarSize(colorbarKey);
	                const colorbarHeightRatio = colorbarAsset ? 0.72 : 0;
	                const colorbarRightInset = colorbarAsset ? 24 : 0;
	                const scale = Math.min(maxWidth / layout.panelWidth, maxHeight / layout.panelHeight);
	                const width = layout.panelWidth * scale;
	                const height = layout.panelHeight * scale;
	                const colorbarHeight = colorbarAsset ? height * colorbarHeightRatio : 0;
	                const colorbarWidth = colorbarAsset ? colorbarSize.width * colorbarHeight / colorbarSize.height : 0;
	                const x = (baseWidth - width) / 2;
	                const y = panelTop + (baseHeight - panelTop - height) / 2;
	                drawDirectMapPanel(focusPanel.image, x, y, width, height);
	                if (colorbarAsset) {
	                    drawBackgroundAsset(
	                        colorbarKey,
	                        x + width - colorbarWidth - colorbarRightInset,
	                        y + (height - colorbarHeight) / 2,
	                        colorbarWidth,
	                        colorbarHeight
	                    );
	                }
	                panelHitAreas.push({
	                    imageKey: focusPanel.imageKey,
	                    x,
	                    y,
	                    width,
	                    height,
	                });
	            }
	        } else {
	            panels.forEach((panel) => {
	                const area = layout.mode === 'direct'
	                    ? getDirectPanelArea(panel)
	                    : drawPanel(createMapPanel(panel.image), panel);
	                if (layout.mode === 'direct') {
	                    drawDirectMapPanel(panel.image, area.x, area.y, area.width, area.height);
	                }
	                panelHitAreas.push({
	                    ...area,
	                    imageKey: panel.imageKey,
	                });
	            });
	            drawOverviewDecorations(panelHitAreas);
	        }
	        if (currentCompositeState) {
	            currentCompositeState.panelHitAreas = panelHitAreas;
	        }
	        canvas.style.cursor = isPanelFocusAvailable()
	            ? (panelViewMode === 'focus' ? 'zoom-out' : 'zoom-in')
	            : 'default';

        ctx.restore();
    }
    // 创建状态显示元素（如果不存在）
    function createStatusElement() {
        const statusElement = document.createElement('div');
        const imgContainer = document.getElementById('weatherCanvas').parentNode;
        // 设置状态元素样式使其覆盖在图片上方
        statusElement.style.position = 'absolute';
        statusElement.style.top = '0';
        statusElement.style.left = '0';
        statusElement.style.width = '100%';
        statusElement.style.height = '100%';
        statusElement.style.backgroundColor = 'rgba(255, 255, 255, 0.8)';
        statusElement.style.display = 'flex';
        statusElement.style.alignItems = 'center';
        statusElement.style.justifyContent = 'center';
        imgContainer.style.position = 'relative';
        imgContainer.appendChild(statusElement);
        return statusElement;
    }
    // 页面加载完成后加载初始图片
    document.addEventListener('DOMContentLoaded', () => {
        setupPanelViewInteractions();
        if (buttons.length > 0) {
            buttons[0].click();
        }
    });
    </script>

<script>
    let carouselInterval;
    let currentIndex = 0;
    let isPlaying = false; // 新增状态变量
    let buttons = document.querySelectorAll('.forcast');
    const toggleBtn = document.getElementById('toggleBtn');
    toggleBtn.addEventListener('click', () => {
        if (buttons.length === 0) return;

        if (isPlaying) {
            // 当前是播放状态，切换到暂停
            clearInterval(carouselInterval);
            toggleBtn.innerHTML = `
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 1408 1600"><!-- Icon from Font Awesome 4 by Dave Gandy - https://scripts.sil.org/cms/scripts/page.php?site_id=nrsi&id=OFL --><path fill="currentColor" d="M1384 831L56 1569q-23 13-39.5 3T0 1536V64q0-26 16.5-36T56 31l1328 738q23 13 23 31t-23 31"/></svg>
                播放
            `;
            toggleBtn.classList.remove('bg-red-500');
            toggleBtn.classList.add('bg-blue-500');
        } else {
            // 当前是暂停状态，切换到播放
            carouselInterval = setInterval(() => {
                currentIndex = (currentIndex + 1) % buttons.length;
                buttons[currentIndex].click();
            }, 1500);
            toggleBtn.innerHTML =  `
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 1536 1536"><!-- Icon from Font Awesome 4 by Dave Gandy - https://scripts.sil.org/cms/scripts/page.php?site_id=nrsi&id=OFL --><path fill="currentColor" d="M1536 64v1408q0 26-19 45t-45 19H960q-26 0-45-19t-19-45V64q0-26 19-45t45-19h512q26 0 45 19t19 45m-896 0v1408q0 26-19 45t-45 19H64q-26 0-45-19t-19-45V64q0-26 19-45T64 0h512q26 0 45 19t19 45"/></svg>
                暂停
            `;
            toggleBtn.classList.remove('bg-blue-500');
            toggleBtn.classList.add('bg-red-500');
        }
        isPlaying = !isPlaying; // 切换状态
    });
</script>

